{
  "hub": {
    "host": "0.0.0.0",
    "port": 3333,
    "logLevel": "info",
    "requestTimeoutMs": 30000,
    "ssePingIntervalMs": 15000
  },
  "servers": {
    "kaic-brain": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/vault"],
      "env": {},
      "autoStart": true,
      "restartDelay": 2000,
      "maxRestarts": 5,
      "healthCheck": {
        "enabled": false
      }
    },
    "echo": {
      "command": "node",
      "args": ["./fixtures/stdio-mcp-echo.mjs"],
      "env": {},
      "autoStart": true,
      "restartDelay": 2000,
      "maxRestarts": 5,
      "healthCheck": {
        "enabled": false
      }
    },
    "figma": {
      "command": "node",
      "args": ["./node_modules/figma-developer-mcp/dist/bin.js", "--stdio"],
      "env": {
        "FIGMA_API_KEY": "${FIGMA_API_KEY}"
      },
      "autoStart": false,
      "restartDelay": 2000,
      "maxRestarts": 5,
      "healthCheck": {
        "enabled": false
      }
    },
    "clickup": {
      "command": "node",
      "args": ["./node_modules/@hauptsache.net/clickup-mcp/dist/index.js"],
      "env": {
        "CLICKUP_API_KEY": "${CLICKUP_API_KEY}",
        "CLICKUP_TEAM_ID": "${CLICKUP_TEAM_ID}"
      },
      "autoStart": false,
      "restartDelay": 2000,
      "maxRestarts": 5,
      "healthCheck": {
        "enabled": false
      }
    },
    "gdrive-pessoal": {
      "command": "node",
      "args": ["./node_modules/@modelcontextprotocol/server-gdrive/dist/index.js"],
      "env": {
        "GDRIVE_OAUTH_PATH": "/app/credentials/gcp-oauth.keys.json",
        "GDRIVE_CREDENTIALS_PATH": "/app/credentials/gdrive-pessoal.json"
      },
      "autoStart": false,
      "restartDelay": 2000,
      "maxRestarts": 5,
      "healthCheck": {
        "enabled": false
      }
    },
    "gdrive-pj": {
      "command": "node",
      "args": ["./node_modules/@modelcontextprotocol/server-gdrive/dist/index.js"],
      "env": {
        "GDRIVE_OAUTH_PATH": "/app/credentials/gcp-oauth.keys.json",
        "GDRIVE_CREDENTIALS_PATH": "/app/credentials/gdrive-pj.json"
      },
      "autoStart": false,
      "restartDelay": 2000,
      "maxRestarts": 5,
      "healthCheck": {
        "enabled": false
      }
    },
    "figma-write": {
      "command": "node",
      "args": ["./fixtures/stdio-mcp-figma-write.mjs"],
      "env": {
        "FIGMA_WRITE_BRIDGE_MODULE": "${FIGMA_WRITE_BRIDGE_MODULE}",
        "FIGMA_WRITE_BRIDGE_URL": "${FIGMA_WRITE_BRIDGE_URL}",
        "FIGMA_WRITE_BRIDGE_TOKEN": "${FIGMA_WRITE_BRIDGE_TOKEN}",
        "FIGMA_WRITE_BRIDGE_TIMEOUT_MS": "${FIGMA_WRITE_BRIDGE_TIMEOUT_MS}"
      },
      "autoStart": false,
      "restartDelay": 2000,
      "maxRestarts": 5,
      "healthCheck": {
        "enabled": false
      }
    }
  }
}
