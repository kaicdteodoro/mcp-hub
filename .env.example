COMPOSE_PROJECT_NAME=mcp-hub
PORT=3333
NODE_ENV=production
FIGMA_API_KEY=
# Gateway hardening
# If set (recommended), endpoints require `Authorization: Bearer <token>`.
MCP_HUB_AUTH_TOKEN=
# Comma-separated list of allowed browser origins (CORS). Example:
# MCP_HUB_CORS_ORIGINS=http://localhost:3000,https://myapp.example
MCP_HUB_CORS_ORIGINS=
# Basic in-memory rate limiting (requests per second + burst).
MCP_HUB_RATE_LIMIT_RPS=10
MCP_HUB_RATE_LIMIT_BURST=20
# SSE session limits (DoS protection)
MCP_HUB_MAX_SESSIONS=200
MCP_HUB_MAX_SESSIONS_PER_SERVER=50
# Secrets are referenced only via mcp-hub.config.json placeholders, e.g.:
# FIGMA_API_KEY=... for figma MCP server
